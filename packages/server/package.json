{
  "name": "@grackle-ai/server",
  "version": "0.76.0",
  "description": "Grackle server orchestrator — spawns and wires core (gRPC), web-server (HTTP), MCP, and PowerLine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nick-pape/grackle.git",
    "directory": "packages/server"
  },
  "keywords": ["grackle", "server", "orchestrator"],
  "homepage": "https://github.com/nick-pape/grackle#readme",
  "bugs": { "url": "https://github.com/nick-pape/grackle/issues" },
  "engines": { "node": ">=22.0.0" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/"],
  "scripts": {
    "build": "heft build --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "heft clean",
    "_phase:build": "heft run --only build -- --clean",
    "_phase:test": "vitest run"
  },
  "dependencies": {
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "@grackle-ai/adapter-codespace": "workspace:*",
    "@grackle-ai/adapter-docker": "workspace:*",
    "@grackle-ai/adapter-local": "workspace:*",
    "@grackle-ai/adapter-sdk": "workspace:*",
    "@grackle-ai/adapter-ssh": "workspace:*",
    "@grackle-ai/auth": "workspace:*",
    "@grackle-ai/common": "workspace:*",
    "@grackle-ai/core": "workspace:*",
    "@grackle-ai/database": "workspace:*",
    "@grackle-ai/mcp": "workspace:*",
    "@grackle-ai/powerline": "workspace:*",
    "@grackle-ai/web-server": "workspace:*",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@grackle-ai/heft-rig": "workspace:*",
    "@rushstack/heft": "1.2.7",
    "@types/node": "^22.0.0",
    "vitest": "^3.1.1"
  }
}
