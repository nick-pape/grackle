{
  "name": "@grackle-ai/knowledge-core",
  "version": "0.62.2",
  "description": "Generic knowledge graph SDK on top of Neo4j with vector search, graph traversal, and pluggable embedders/chunkers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nick-pape/grackle.git",
    "directory": "packages/knowledge-core"
  },
  "keywords": ["knowledge-graph", "neo4j", "vector-search", "embeddings", "graph-traversal"],
  "engines": { "node": ">=22.0.0" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/"],
  "scripts": {
    "build": "heft build --clean",
    "test": "vitest run",
    "clean": "heft clean",
    "_phase:build": "heft run --only build -- --clean",
    "_phase:test": "vitest run"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "neo4j-driver": "^6.0.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@grackle-ai/heft-rig": "workspace:*",
    "@rushstack/heft": "1.2.4",
    "@types/node": "^22.0.0",
    "vitest": "^3.1.1"
  }
}
