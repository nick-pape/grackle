{
  "disallowedTools": ["mcp__playwright__browser_install"],
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--executable-path=/ms-playwright/chromium-1208/chrome-linux64/chrome", "--no-sandbox"],
      "env": { "DISPLAY": ":99" }
    },
    "pockettts": {
      "command": "/opt/pockettts/bin/python",
      "args": ["/app/mcp-pockettts/server.py"],
      "env": { "DISPLAY": ":99" }
    }
  }
}
