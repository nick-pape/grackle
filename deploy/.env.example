# Grackle Docker Compose environment variables.
# Copy this file to .env and uncomment/edit the values you need.

# ── Image ────────────────────────────────────────────────────
# Pin to a specific nightly build for reproducibility, or use "latest".
# GRACKLE_VERSION=latest

# ── Ports ────────────────────────────────────────────────────
# Web UI port on the host (default: 3000).
# GRACKLE_WEB_PORT=3000

# ── GitHub ───────────────────────────────────────────────────
# GitHub CLI token — required for the Codespace adapter and private repos.
# Generate with: gh auth token
# GH_TOKEN=

# ── Knowledge graph ──────────────────────────────────────────
# Neo4j runs embedded by default. Set these to use an external instance:
# GRACKLE_NEO4J_URL=bolt://your-neo4j:7687
# GRACKLE_NEO4J_USER=neo4j
# GRACKLE_NEO4J_PASSWORD=your-password
# GRACKLE_NEO4J_DATABASE=neo4j

# Set to "false" to disable the knowledge graph entirely:
# GRACKLE_KNOWLEDGE_ENABLED=false
