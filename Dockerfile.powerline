# ─── Base stage: shared setup for both production and dev ────
FROM node:22-slim AS base

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Create non-root user for running the PowerLine
RUN groupadd -r grackle && useradd -r -g grackle -m grackle

# Workspace for agent operations — mount your repo here
RUN mkdir -p /workspace && chown grackle:grackle /workspace

# Claude Agent SDK expects ~/.claude/debug to exist for logging
RUN mkdir -p /home/grackle/.claude/debug && chown -R grackle:grackle /home/grackle/.claude

EXPOSE 7433

# ─── Production: npm install from registry ──────────────────
FROM base AS production

ARG POWERLINE_VERSION=latest
WORKDIR /app

RUN npm init -y && npm install @grackle-ai/powerline@${POWERLINE_VERSION} --omit=dev --legacy-peer-deps

# Chromium needs >64MB shared memory for rendering
USER grackle
# --experimental-specifier-resolution=node works around vscode-jsonrpc missing .js
# in ESM imports, required by @github/copilot-sdk (upstream bug in vscode-jsonrpc@8.x)
CMD ["node", "--experimental-specifier-resolution=node", "node_modules/@grackle-ai/powerline/dist/index.js", "--port=7433", "--host=0.0.0.0"]

# ─── Dev: copy local monorepo artifacts ─────────────────────
FROM base AS dev

WORKDIR /app

# Copy powerline dist + package.json
COPY packages/powerline/dist/ /app/dist/
COPY packages/powerline/package.json /app/package.json

# Strip private @grackle-ai/* deps before npm install
RUN node -e "\
  const p=JSON.parse(require('fs').readFileSync('package.json','utf8'));\
  for(const k of Object.keys(p.dependencies||{})){if(k.startsWith('@grackle-ai/'))delete p.dependencies[k];}\
  for(const k of Object.keys(p.devDependencies||{})){if(k.startsWith('@grackle-ai/'))delete p.devDependencies[k];}\
  require('fs').writeFileSync('package.json',JSON.stringify(p,null,2));"
RUN npm install --omit=dev --legacy-peer-deps

# Copy @grackle-ai/common AFTER npm install (npm cleans unmanaged dirs in node_modules)
COPY packages/common/dist/ /app/node_modules/@grackle-ai/common/dist/
COPY packages/common/package.json /app/node_modules/@grackle-ai/common/package.json

# Copy @grackle-ai/mcp for MCP server support
COPY packages/mcp/dist/ /app/node_modules/@grackle-ai/mcp/dist/
COPY packages/mcp/package.json /app/node_modules/@grackle-ai/mcp/package.json

# Install runtime deps for copied @grackle-ai/* packages (e.g. fuse.js for common)
RUN cd node_modules/@grackle-ai/common && npm install --omit=dev --legacy-peer-deps --no-package-lock 2>/dev/null; true

USER grackle

# Run PowerLine from /app so node_modules resolve correctly
# Agents will use /workspace as their cwd
# --experimental-specifier-resolution=node works around vscode-jsonrpc missing .js
# in ESM imports, required by @github/copilot-sdk (upstream bug in vscode-jsonrpc@8.x)
CMD ["node", "--experimental-specifier-resolution=node", "dist/index.js", "--port=7433", "--host=0.0.0.0"]
