FROM node:22-slim

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Create non-root user for running the PowerLine
RUN groupadd -r grackle && useradd -r -g grackle -m grackle

WORKDIR /app

# Create a standalone package that combines common + powerline
COPY packages/common/dist/ /app/node_modules/@grackle/common/dist/
COPY packages/common/package.json /app/node_modules/@grackle/common/package.json

COPY packages/powerline/dist/ /app/dist/
COPY packages/powerline/package.json /app/package.json

# Install runtime dependencies (not from Rush — standalone npm install)
RUN npm install --omit=dev \
    @bufbuild/protobuf@^2.5.0 \
    @connectrpc/connect@^2.0.0 \
    @connectrpc/connect-node@^2.0.0 \
    @anthropic-ai/claude-agent-sdk@0.2.50

# MCP: Grackle coordination tools (post_finding, query_findings)
COPY packages/powerline/mcp-grackle/ /app/mcp-grackle/
RUN cd /app/mcp-grackle && npm install --omit=dev

# Workspace for agent operations — mount your repo here
RUN mkdir -p /workspace && chown grackle:grackle /workspace

# Claude Agent SDK expects ~/.claude/debug to exist for logging
RUN mkdir -p /home/grackle/.claude/debug && chown -R grackle:grackle /home/grackle/.claude

EXPOSE 7433

USER grackle

# Run PowerLine from /app so node_modules resolve correctly
# Agents will use /workspace as their cwd
WORKDIR /app
CMD ["node", "dist/index.js", "--port=7433"]
