{
  "name": "@grackle-ai/github-import",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.0.0 <24.0.0"
  },
  "private": true,
  "description": "Standalone script to import GitHub issues as Grackle tasks",
  "type": "module",
  "main": "dist/import-github-issues.js",
  "bin": {
    "import-github-issues": "dist/import-github-issues.js"
  },
  "scripts": {
    "build": "heft build --clean",
    "test": "vitest run",
    "clean": "heft clean",
    "_phase:build": "heft run --only build -- --clean",
    "_phase:test": "vitest run"
  },
  "dependencies": {
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "@grackle-ai/common": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@grackle-ai/heft-rig": "workspace:*",
    "@rushstack/heft": "1.2.7",
    "@types/node": "^22.0.0",
    "vitest": "^3.1.1"
  }
}
