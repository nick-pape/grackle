# Grackle Environment Variables
# Copy this file to .env and uncomment/edit the values you need.
# See also: deploy/.env.example for Docker Compose-specific variables.

# ── Paths ──────────────────────────────────────────────────────────
# Root data directory for configuration, database, and API keys.
# GRACKLE_HOME=~/.grackle

# ── Server Ports ───────────────────────────────────────────────────
# gRPC server port.
# GRACKLE_PORT=7434

# Web UI + WebSocket server port.
# GRACKLE_WEB_PORT=3000

# MCP server port.
# GRACKLE_MCP_PORT=7435

# Local PowerLine (agent runtime) port.
# GRACKLE_POWERLINE_PORT=7433

# ── Server Bind Address ───────────────────────────────────────────
# Bind address for the server. Default is localhost only.
# Set to 0.0.0.0 for LAN access (e.g., phone). Use `grackle pair` to
# generate pairing codes for remote clients.
# GRACKLE_HOST=127.0.0.1

# ── Client Connection ─────────────────────────────────────────────
# gRPC server URL used by the CLI and MCP clients.
# GRACKLE_URL=http://127.0.0.1:7434

# API key for authenticating with the server.
# Generated automatically on first run; override for scripted setups.
# GRACKLE_API_KEY=

# ── Server Behavior ───────────────────────────────────────────────
# Set to "1" to skip auto-starting the local PowerLine server.
# Useful when running PowerLine separately or on a remote host.
# GRACKLE_SKIP_LOCAL_POWERLINE=

# Set to "1" to disable the orchestration plugin (tasks, personas, findings,
# escalations). When set, the server runs in core-only mode (sessions + environments).
# GRACKLE_SKIP_ORCHESTRATION=

# Directory containing the compiled web UI assets.
# GRACKLE_WEB_DIR=

# ── Encryption ─────────────────────────────────────────────────────
# Encryption key for token storage. If unset, generated and saved to
# $GRACKLE_HOME/master-key on first run.
# GRACKLE_MASTER_KEY=

# ── PowerLine ──────────────────────────────────────────────────────
# Authentication token for the PowerLine server.
# GRACKLE_POWERLINE_TOKEN=

# ── MCP Configuration ─────────────────────────────────────────────
# Path to MCP servers config JSON file (read by runtimes for tool
# registration).
# GRACKLE_MCP_CONFIG=

# ── Docker Adapter ─────────────────────────────────────────────────
# Docker network name for Docker-outside-of-Docker (DooD) setups.
# When set, containers reach the server via network name instead of
# host port mapping.
# GRACKLE_DOCKER_NETWORK=

# DooD host address. When set, wildcard bind addresses (0.0.0.0, ::)
# resolve to this value so containers can reach the server.
# GRACKLE_DOCKER_HOST=

# ── Knowledge Graph (Neo4j) ───────────────────────────────────────
# Set GRACKLE_KNOWLEDGE_ENABLED=true to enable the knowledge graph.
# GRACKLE_KNOWLEDGE_ENABLED=false

# Neo4j connection settings (only used when knowledge graph is enabled).
# GRACKLE_NEO4J_URL=bolt://127.0.0.1:7687
# GRACKLE_NEO4J_USER=neo4j
# GRACKLE_NEO4J_PASSWORD=grackle-dev
# GRACKLE_NEO4J_DATABASE=neo4j

# ── Concurrency ──────────────────────────────────────────────────
# Reconciliation tick interval in milliseconds (default: 10000).
# GRACKLE_RECONCILIATION_TICK_MS=10000

# ── Logging ────────────────────────────────────────────────────────
# Pino log level: debug, info, warn, error, fatal.
# LOG_LEVEL=info

# Node environment. When not "production", logs are pretty-printed.
# NODE_ENV=

# ── Web UI (Vite build-time) ──────────────────────────────────────
# Base URL path for subpath deployments (e.g., /grackle/).
# VITE_BASE_URL=/

# Enable demo mode in the web UI (compiled in at build time).
# VITE_DEMO_MODE=false

# ── Third-Party Providers ─────────────────────────────────────────
# OpenAI API key for the Codex runtime.
# OPENAI_API_KEY=

# Override for OpenAI API key (explicit Codex runtime configuration).
# CODEX_API_KEY=

# Custom OpenAI API base URL (for proxies or alternative providers).
# OPENAI_BASE_URL=

# GitHub CLI token (used by Codespace adapter and private repos).
# Generate with: gh auth token
# GH_TOKEN=
