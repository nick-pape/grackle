{
  "$schema": "https://developer.microsoft.com/json-schemas/heft/v0/heft.schema.json",
  "phasesByName": {
    "build": {
      "cleanFiles": [
        { "sourcePath": "dist" },
        { "sourcePath": "src/gen" }
      ],
      "tasksByName": {
        "buf-lint": {
          "taskPlugin": {
            "pluginPackage": "@grackle-ai/heft-buf-plugin",
            "pluginName": "buf-lint-plugin"
          }
        },
        "buf-generate": {
          "taskDependencies": ["buf-lint"],
          "taskPlugin": {
            "pluginPackage": "@grackle-ai/heft-buf-plugin",
            "pluginName": "buf-generate-plugin"
          }
        },
        "typescript": {
          "taskDependencies": ["buf-generate"],
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft-typescript-plugin"
          }
        },
        "lint": {
          "taskDependencies": ["typescript"],
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft-lint-plugin"
          }
        }
      }
    }
  }
}
