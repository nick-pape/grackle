{
  "$schema": "https://developer.microsoft.com/json-schemas/heft/v0/heft.schema.json",
  "phasesByName": {
    "build": {
      "cleanFiles": [
        { "sourcePath": "dist" },
        { "sourcePath": "storybook-static" }
      ],
      "tasksByName": {
        "typescript": {
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft-typescript-plugin"
          }
        },
        "lint": {
          "taskDependencies": ["typescript"],
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft-lint-plugin"
          }
        },
        "vite-build": {
          "taskDependencies": ["typescript"],
          "taskPlugin": {
            "pluginPackage": "@grackle-ai/heft-vite-plugin",
            "pluginName": "vite-build-plugin"
          }
        },
        "storybook-build": {
          "taskDependencies": ["typescript"],
          "taskPlugin": {
            "pluginPackage": "@grackle-ai/heft-web-test-plugin",
            "pluginName": "storybook-build-plugin"
          }
        }
      }
    },
    "test": {
      "phaseDependencies": ["build"],
      "tasksByName": {
        "vitest": {
          "taskPlugin": {
            "pluginPackage": "@grackle-ai/heft-web-test-plugin",
            "pluginName": "vitest-plugin"
          }
        },
        "storybook-test": {
          "taskPlugin": {
            "pluginPackage": "@grackle-ai/heft-web-test-plugin",
            "pluginName": "storybook-test-plugin"
          }
        }
      }
    }
  }
}
